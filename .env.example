# Публичная конфигурация Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Серверная конфигурация Supabase / Postgres
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=postgres://freightpilot:freightpilot@localhost:5432/freightpilot

# Конфигурация AI
AI_PROVIDER=lmstudio
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
LMSTUDIO_BASE_URL=http://192.168.50.232:1234/v1
LMSTUDIO_MODEL=google/gemma-4-12b-qat
LMSTUDIO_TIMEOUT_MS=10000
LMSTUDIO_MAX_TOKENS=700
LMSTUDIO_TEMPERATURE=0
LMSTUDIO_TOP_P=0.1
LMSTUDIO_STRUCTURED_OUTPUT=true
# Опционально. Оставьте пустым, если загруженная модель или сервер не поддерживает параметр стабильно.
LMSTUDIO_REASONING_EFFORT=

# Конфигурация демо
DEMO_TENANT_ID=demo_freightpilot
DEMO_MODE=guided
